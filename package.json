{
  "name": "svitlobot",
  "version": "1.0.0",
  "description": "Multi-tenant Telegram бот СвітлоБот для моніторингу відключень електроенергії в Україні",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose",
    "test:legacy": "node tests/legacy/test.js && node tests/legacy/test-scaling.js",
    "test:all": "npm test && npm run test:legacy",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": [
    "telegram",
    "bot",
    "ukraine",
    "electricity",
    "outage",
    "monitor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/hydrate": "^1.6.0",
    "@grammyjs/runner": "^2.0.3",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "grammy": "^1.40.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/unit/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/bot.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 10,
        "functions": 10,
        "branches": 5,
        "statements": 10
      }
    }
  }
}
