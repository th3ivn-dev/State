# === Telegram Bot ===
# Токен бота від @BotFather (обов'язково)
BOT_TOKEN=your_telegram_bot_token_here
# Telegram ID власника бота (опціонально — без нього функції власника недоступні)
OWNER_ID=your_telegram_user_id_here
# Список Telegram ID адміністраторів через кому (опціонально)
ADMIN_IDS=123456789,987654321

# === Database ===
# PostgreSQL: дані для підключення
POSTGRES_USER=voltyk
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=voltyk_bot
# Повний рядок підключення до бази даних
DATABASE_URL=postgresql://voltyk:change_me_in_production@postgres:5432/voltyk_bot

# === Timezone ===
# Часовий пояс (за замовчуванням Europe/Kyiv)
TZ=Europe/Kyiv

# === Моніторинг світла (опціонально) ===
# IP-адреса домашнього роутера для ping-моніторингу
ROUTER_HOST=
# Порт роутера (за замовчуванням 80)
ROUTER_PORT=80

# === Масштабування (опціонально — є значення за замовчуванням) ===
# Максимальна кількість з'єднань у пулі БД
DB_POOL_MAX=50
# Мінімальна кількість з'єднань у пулі БД
DB_POOL_MIN=5
# Ліміт повідомлень Telegram на секунду
TELEGRAM_RATE_LIMIT=25
# Кількість спроб повторного відправлення повідомлення
MESSAGE_RETRY_COUNT=3
# Кількість паралельних регіонів у планувальнику
SCHEDULER_BATCH_SIZE=5
# Затримка між користувачами в мс
SCHEDULER_STAGGER_MS=50

# === HTTP Сервер ===
# Порт для health-check та webhook (за замовчуванням 3000)
PORT=3000
# Альтернативна змінна порту для health-check
HEALTH_PORT=3000

# === Webhook (опціонально — за замовчуванням використовується polling) ===
# Увімкнути webhook замість polling
# USE_WEBHOOK=true
# Публічна URL вашого сервера (потрібна для webhook)
# WEBHOOK_URL=https://your-app.railway.app
# Шлях webhook (за замовчуванням /webhook/<BOT_TOKEN>)
# WEBHOOK_PATH=/webhook/your_bot_token_here
# Порт webhook (за замовчуванням збігається з PORT)
# WEBHOOK_PORT=3000
# Максимальна кількість одночасних webhook-з'єднань
# WEBHOOK_MAX_CONNECTIONS=100

# === Логування ===
# Рівень логів: error | warn | info | debug (за замовчуванням info)
LOG_LEVEL=info

# === Node.js ===
# Середовище запуску: development | production
NODE_ENV=production

# === Railway (автоматично встановлюється платформою) ===
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_NAME=your_project_name
# RAILWAY_SERVICE_NAME=your_service_name
